# DeepSeek API Configuration (default models)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Qwen API Configuration (alternative models)
QWEN_API_KEY=your_qwen_api_key_here

# OpenAI API Configuration (optional)
OPENAI_API_KEY=

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=

# Google API Configuration (optional)
GOOGLE_API_KEY=

# Tavily Search API Configuration
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false